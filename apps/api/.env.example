APP_NAME="YouTube Transcript Chatbot API"
APP_ENV=local
WEB_ORIGIN=http://localhost:3000
WEB_ORIGINS=http://localhost:3000

# Hugging Face Inference Providers. Leave empty for local fallback responses.
HF_TOKEN=
HF_MODEL=openai/gpt-oss-120b:fastest
HF_TIMEOUT_SECONDS=20

# RAG indexing: choose "huggingface" for Hugging Face hosted embeddings or "openai" for OpenAIEmbeddings.
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4
