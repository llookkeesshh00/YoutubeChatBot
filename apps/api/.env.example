APP_NAME="YouTube Transcript Chatbot API"
APP_ENV=local
WEB_ORIGIN=http://localhost:3000

# Hugging Face Inference Providers. Leave empty for local fallback responses.
HF_TOKEN=
HF_MODEL=openai/gpt-oss-120b:fastest

# Local embedding model used by sentence-transformers.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

